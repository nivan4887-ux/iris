# Required
OPENAI_API_KEY=sk-...

# Optional — only needed if VISION_PROVIDER=gemini
GEMINI_API_KEY=

# Redis (leave default for local Docker, change for cloud Redis)
REDIS_URL=redis://localhost:6379

# Vision model provider: "openai" (gpt-4o) or "gemini"
VISION_PROVIDER=openai

# Seconds before the same narration can repeat (deduplication cooldown)
NARRATION_COOLDOWN_SECONDS=3

# Max entries kept in decision history per session
MAX_HISTORY_ITEMS=50
